# .env.example — copy to .env and fill in values before Day 9.
# .env is gitignored. This file IS committed.

# --- OpenWeather (Day 9) ---
# Sign up at https://openweathermap.org/api → One Call API 3.0 (free tier works)
OPENWEATHER_API_KEY=

# Bengaluru coordinates (default — change only if targeting a different city)
OPENWEATHER_LAT=12.9716
OPENWEATHER_LON=77.5946

# --- Gemini (Day 9) ---
# Sign up at https://aistudio.google.com → Get API Key
GEMINI_API_KEY=